{
  "name": "conscious-pregnancy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint -c oxlint.json --tsconfig tsconfig.json",
    "lint:fix": "oxlint -c oxlint.json --tsconfig tsconfig.json --fix",
    "format": "oxfmt --config ./.oxfmtrc.json --ignore-path ../.gitignore --check .",
    "format:fix": "oxfmt --config ./.oxfmtrc.json --ignore-path ../.gitignore --write .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "test:e2e": "playwright test",
    "crawl:clearpath": "playwright test e2e/crawl.clearpath.spec.ts --project=chromium",
    "crawl:clearpath:ui": "playwright test e2e/crawl.clearpath.spec.ts --project=chromium --ui",
    "capture:local": "PW_LOCAL=1 playwright test e2e/local.capture.spec.ts --project=chromium",
    "extract:blueprint": "playwright test e2e/extract.blueprint.spec.ts --project=chromium",
    "extract:screenshots": "PW_LOCAL=1 playwright test e2e/extract.screenshots.spec.ts --project=chromium",
    "extract:styles": "playwright test e2e/extract.styles.spec.ts --project=chromium",
    "extract:animations": "playwright test e2e/extract.animations.spec.ts --project=chromium",
    "extract:scroll-sequence": "playwright test e2e/extract.scroll-sequence.spec.ts --project=chromium",
    "extract:scroll-sequence:local": "PW_LOCAL=1 playwright test e2e/extract.scroll-sequence.spec.ts --project=chromium",
    "extract:video": "playwright test e2e/extract.video.spec.ts --project=chromium",
    "extract:all": "playwright test e2e/extract.blueprint.spec.ts e2e/extract.styles.spec.ts e2e/extract.animations.spec.ts --project=chromium && PW_LOCAL=1 playwright test e2e/extract.screenshots.spec.ts --project=chromium",
    "typegen": "sanity typegen generate",
    "seed:pages": "tsx scripts/seed-pages.ts",
    "seed:cms-layout": "node scripts/seed-cms-layout.mjs",
    "sanity:publish-drafts": "node scripts/publish-drafts.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@portabletext/react": "^3.1.0",
    "@portabletext/types": "^4.0.2",
    "@sanity/client": "^7.22.0",
    "@sanity/image-url": "^2.1.1",
    "gsap": "^3.14.2",
    "lenis": "^1.3.21",
    "next": "^16.2.2",
    "next-sanity": "^12.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "^5.23.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260211.1",
    "bun-types": "^1.3.8",
    "knip": "^5.83.0",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "typescript": "^5.8.3"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead"
  ]
}
